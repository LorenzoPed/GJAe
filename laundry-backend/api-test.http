### 1. Register a new User
# We create a user named "Elena" with role USER
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "name": "Elena",
  "username": "elena",
  "email": "elena@test.com",
  "password": "password123"
}

### 2. Login to get the Token
# Use the same credentials to receive the JWT Token
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "username": "elena",
  "password": "password123"
}

### 3. Get All Machines (PROTECTED)
# REPLACE 'YOUR_TOKEN_HERE' with the token string you got from the Login response
GET http://localhost:8080/api/machines
Authorization: Bearer YOUR_TOKEN_HERE